---
import Magazine from '../layouts/Magazine.astro';
import HeroImage from '../components/HeroImage.astro';
import CoverHeader from '../components/CoverHeader.astro';
import Zitat from '../components/Zitat.astro';
import GeschichteStrip from '../components/GeschichteStrip.astro';
import EventBanner from '../components/EventBanner.astro';
import WetterCard from '../components/WetterCard.astro';
import KalenderCard from '../components/KalenderCard.astro';
import KryptoCard from '../components/KryptoCard.astro';
import MacroCard from '../components/MacroCard.astro';
import NewsCard from '../components/NewsCard.astro';
import CoverFooter from '../components/CoverFooter.astro';
---

<Magazine title="Cover · Mario's HQ">
  <div class="cover-page">
    <HeroImage />
    <div class="cover-content">
      <CoverHeader />
      <Zitat />
      <GeschichteStrip />
      <EventBanner />
      <div class="co-heroes">
        <WetterCard />
        <KalenderCard />
      </div>
      <div class="supporting">
        <KryptoCard />
        <MacroCard />
        <NewsCard />
      </div>
      <CoverFooter />
    </div>
  </div>
</Magazine>

<style>
  .cover-page {
    max-width: var(--container);
    margin: var(--s-4) auto 0;
  }

  /* Horizontales Padding für Text-Inhalte — Hero-Bild bleibt vollbreite */
  .cover-content {
    padding: 0 var(--s-5);
  }

  /* Co-Heroes: Wetter links (1.7fr) · Kalender rechts (1fr)
     minmax(0, …) verhindert Overflow bei langem Card-Inhalt */
  .co-heroes {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
    gap: 14px;
    margin-top: var(--s-4);
  }

  @media (max-width: 767px) {
    .co-heroes {
      grid-template-columns: 1fr;
    }
  }

  /* Supporting-3er-Reihe: Krypto · Macro · News */
  .supporting {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 14px;
  }

  @media (max-width: 767px) {
    .supporting {
      grid-template-columns: 1fr;
    }
  }
</style>
