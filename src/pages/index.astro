---
export const prerender = false;

// Cover-Page · SSR · Live-Fetches zum Page-Load
// Slice 5.1: KryptoCard zieht echte CoinGecko-Preise + Fear & Greed.
// Wetter/Kalender/Macro/News/EventBanner: noch Stub, kommt in 5.2 + 5.3.
// Cache-Header analog /wirtschaft: 60s frisch, 300s SWR.

import Magazine from '../layouts/Magazine.astro';
import HeroImage from '../components/HeroImage.astro';
import CoverHeader from '../components/CoverHeader.astro';
import Zitat from '../components/Zitat.astro';
import GeschichteStrip from '../components/GeschichteStrip.astro';
// EventBanner in Slice 5.3 stillgelegt · Komponente bleibt im Repo erhalten
// (Wiederanschluss möglich, siehe PHASE-5-COVER-SYNC-SPEC.md §4.6)
import WetterCard from '../components/WetterCard.astro';
import KalenderCard from '../components/KalenderCard.astro';
import KryptoCard from '../components/KryptoCard.astro';
import MacroCard from '../components/MacroCard.astro';
import NewsCard from '../components/NewsCard.astro';
import CoverFooter from '../components/CoverFooter.astro';

import { getKryptoStand }      from '../lib/coingeckoFetcher';
import { getFearGreed }        from '../lib/fearGreedFetcher';
import { getWetterErgebnis }   from '../lib/openMeteoFetcher';
import { getStundenHeute }     from '../lib/astronomieResolver';
import { getFotoEmpfehlung }   from '../lib/fotoSpotPicker';
import { getKalenderTermine }  from '../lib/icalFetcher';

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

// Parallele Fetches · jeder mit eigenem Fallback (siehe Fetcher-Implementierungen)
const [krypto, fearGreed, wetter, kalender] = await Promise.all([
  getKryptoStand(),
  getFearGreed(),
  getWetterErgebnis(),
  getKalenderTermine(),
]);

// Synchron · brauchen kein await
const stunden = getStundenHeute();
const foto    = getFotoEmpfehlung(wetter.heute);  // braucht wetter.heute, muss NACH dem await stehen
// MacroCard liest selbst aus macroEventsResolver (synchron, kein Props-Bottleneck nötig)
// NewsCard liest selbst aus newsResolver (synchron, kein Props-Bottleneck nötig)
---

<Magazine title="Cover · Mario's HQ">
  <div class="cover-page">
    <HeroImage />
    <div class="cover-content">
      <CoverHeader />
      <Zitat />
      <GeschichteStrip />
      <div class="co-heroes">
        <WetterCard wetter={wetter} stunden={stunden} foto={foto} />
        <KalenderCard ergebnis={kalender} />
      </div>
      <div class="supporting">
        <KryptoCard krypto={krypto} fearGreed={fearGreed} />
        <MacroCard />
        <NewsCard />
      </div>
      <CoverFooter />
    </div>
  </div>
</Magazine>

<style>
  .cover-page {
    max-width: var(--container);
    margin: var(--s-4) auto 0;
  }

  /* Horizontales Padding für Text-Inhalte — Hero-Bild bleibt vollbreite */
  .cover-content {
    padding: 0 var(--s-5);
  }

  /* Co-Heroes: Wetter links (1.7fr) · Kalender rechts (1fr)
     minmax(0, …) verhindert Overflow bei langem Card-Inhalt */
  .co-heroes {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
    gap: 14px;
    margin-top: var(--s-4);
  }

  @media (max-width: 767px) {
    .co-heroes {
      grid-template-columns: 1fr;
    }
  }

  /* Supporting-3er-Reihe: Krypto · Macro · News */
  .supporting {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 14px;
  }

  @media (max-width: 767px) {
    .supporting {
      grid-template-columns: 1fr;
    }
  }
</style>
