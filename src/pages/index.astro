---
import Magazine from '../layouts/Magazine.astro';
import DateDisplay from '../components/layout/DateDisplay.astro';
---

<Magazine title="Cover · Mario's HQ">
  <main class="cover">
    <p class="eyebrow">Mario&rsquo;s HQ · Phase 2.1</p>
    <DateDisplay variant="hero" />
    <p class="lead">
      Information-Architektur steht. Die Module folgen in den nächsten Phasen —
      siehe Navigation oben.
    </p>
  </main>
</Magazine>

<style>
  .cover {
    max-width: var(--container-text);
    margin: var(--s-9) auto;
    padding: 0 var(--s-5);
  }

  .eyebrow {
    margin: 0 0 var(--s-5);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--fg-subtle);
    font-weight: 500;
  }

  .lead {
    margin: var(--s-6) 0 0;
    font-size: var(--fs-body-l);
    color: var(--fg-muted);
    max-width: 56ch;
    line-height: 1.5;
  }
</style>
