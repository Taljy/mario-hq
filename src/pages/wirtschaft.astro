---
export const prerender = false;

// /wirtschaft — SSR · Live-APIs parallel · 60s Edge-Cache via Vercel
// Twelve Data: zwei eigene Endpoints /api/aktien (20min Cache) + /api/forex (22min)
// sequenzielle Fetches wegen 8/min-Credits-Limit (Erkenntnis aus Slice 4.5)
// 4.5b: Krypto-Sektion auf AssetCard-Grid umgestellt · Aktien nicht mehr doppelt
//       Aktien + Forex haben jetzt eigene Definitions-Quellen (data/aktien.ts / forex.ts)
//       watchlist.json enthält nur noch Krypto-Blöcke
// Statische Inhalte (News · Trade-Setups-Platzhalter) aus wirtschaft.json

import DetailPage from '../layouts/DetailPage.astro';
import KryptoHero                from '../components/wirtschaft/KryptoHero.astro';
import TradingIndikatoren        from '../components/wirtschaft/TradingIndikatoren.astro';
import KryptoSektion             from '../components/wirtschaft/KryptoSektion.astro';
import AktienSektion             from '../components/wirtschaft/AktienSektion.astro';
import ForexCommoditiesSektion   from '../components/wirtschaft/ForexCommoditiesSektion.astro';
import MacroTimeline             from '../components/wirtschaft/MacroTimeline.astro';
import FearGreedGauge            from '../components/wirtschaft/FearGreedGauge.astro';
import WirtschaftsNews           from '../components/wirtschaft/WirtschaftsNews.astro';
import TradeSetupsPlaceholder    from '../components/wirtschaft/TradeSetupsPlaceholder.astro';

import { getKryptoStand, getBTCHistory } from '../lib/coingeckoFetcher';
import { getBinanceMetrics }             from '../lib/binanceFetcher';
import { getCoinbasePremium }            from '../lib/coinbasePremiumFetcher';
import { getStablecoinSupply }           from '../lib/defiLlamaFetcher';
import { getKryptoWatchlist }            from '../lib/kryptoAggregator';
import { getWirtschaft }                 from '../lib/wirtschaftResolver';
import { getMacroEvents }                from '../lib/macroEventsResolver';
import { getFearGreed }                  from '../lib/fearGreedFetcher';
import type { TwelveDataStand }          from '../lib/twelveDataFetcher';

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

// Twelve-Data-Endpoints sequenziell · jeder mit eigenem Edge-Cache (siehe
// /api/aktien + /api/forex). Sequenziell statt parallel, damit beide Cold-Start-
// Calls nicht in dieselbe Millisekunde feuern und das 8/min-Limit triggern.
// Defensive: bei jedem Fehler leere Liste · Sektionen rendern dann offline-Stub
async function holeAktienUndForex(origin: string): Promise<{ aktien: TwelveDataStand[]; forex: TwelveDataStand[] }> {
  let aktien: TwelveDataStand[] = [];
  let forex:  TwelveDataStand[] = [];
  try {
    const res = await fetch(`${origin}/api/aktien`);
    if (res.ok) aktien = (await res.json()) as TwelveDataStand[];
  } catch { /* aktien bleibt leer */ }
  try {
    const res = await fetch(`${origin}/api/forex`);
    if (res.ok) forex = (await res.json()) as TwelveDataStand[];
  } catch { /* forex bleibt leer */ }
  return { aktien, forex };
}

const origin = Astro.url.origin;

// Parallele Fetches · jeder Fetcher hat eigenen Fallback
// CoinGecko-Note: getKryptoStand() + getKryptoStandFuerIds() (via getKryptoWatchlist) feuern simultan
// zwei /coins/markets-Calls — akzeptiert für MVP, Merge-Optimierung in Slice 4.8
const [krypto, btcHistory, binance, coinbasePrem, stablecoins, watchlist, td, fearGreed] = await Promise.all([
  getKryptoStand(),
  getBTCHistory(),
  getBinanceMetrics(),
  getCoinbasePremium(),
  getStablecoinSupply(),
  getKryptoWatchlist(),
  holeAktienUndForex(origin),
  getFearGreed(),
]);

const macroEvents = getMacroEvents();
const { news, trade_setups_placeholder } = getWirtschaft();
---

<DetailPage
  title="Wirtschaft"
  eyebrow="Krypto · Aktien · News"
  modul="wirtschaft"
>
  <div class="w-stack">
    <KryptoHero ergebnis={krypto} btcHistory={btcHistory} />
    <TradingIndikatoren
      binance={binance}
      coinbasePrem={coinbasePrem}
      stablecoins={stablecoins}
    />
    <KryptoSektion watchlist={watchlist} />
    <AktienSektion stand={td.aktien} fetch_zeit={watchlist.fetch_zeit} />
    <ForexCommoditiesSektion stand={td.forex} fetch_zeit={watchlist.fetch_zeit} />
    <MacroTimeline events={macroEvents} />
    <FearGreedGauge stand={fearGreed} />
    <WirtschaftsNews items={news} />
    <TradeSetupsPlaceholder text={trade_setups_placeholder} />
  </div>
</DetailPage>

<style>
  .w-stack {
    display: flex;
    flex-direction: column;
    gap: var(--s-6);
  }
</style>
