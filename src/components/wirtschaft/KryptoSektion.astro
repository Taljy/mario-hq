---
// KryptoSektion — Wrapper für die Krypto-Watchlist · zwei thematische Blöcke (4.5b)
// Eyebrow konsistent zu TradingIndikatoren und anderen /wirtschaft-Sektionen
// Props: WatchlistErgebnis (Krypto-only · Typ wird in 4.5c umbenannt)

import type { WatchlistErgebnis } from '../../lib/watchlistAggregator';
import KryptoGruppe from './KryptoGruppe.astro';

interface Props {
  watchlist: WatchlistErgebnis;
}

const { watchlist } = Astro.props;

const stempelLabel = watchlist.ist_live
  ? `Live · ${watchlist.fetch_zeit}`
  : `Fallback · ${watchlist.fetch_zeit}`;
---

<section class="krypto-sektion">

  <div class="sektion-head">
    <span class="eyebrow">Krypto · Watchlist</span>
    <span class={`live-stempel ${!watchlist.ist_live ? 'offline' : ''}`}>{stempelLabel}</span>
  </div>

  <div class="gruppen-stack">
    {watchlist.gruppen.map((gruppe) => (
      <KryptoGruppe gruppe={gruppe} />
    ))}
  </div>

</section>

<style>
  .krypto-sektion {
    background:    var(--bg-card);
    padding:       18px;
    border-radius: 4px;
  }

  /* Kopfzeile */
  .sektion-head {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
    margin-bottom:   var(--s-4);
  }

  .eyebrow {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--accent);
  }

  .live-stempel {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
  }

  .live-stempel.offline {
    color:   var(--accent);
    opacity: 0.7;
  }

  /* Gruppen-Stack · pro Gruppe ein eigener Block mit Header + Card-Grid */
  .gruppen-stack {
    display:        flex;
    flex-direction: column;
    gap:            var(--s-4);
  }
</style>
