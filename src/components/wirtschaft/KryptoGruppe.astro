---
// KryptoGruppe — Collapsible Block mit Header + Card-Grid (4.5b)
// Toggle: Button + aria-expanded · KEIN <details> (Phase-2.1-Stolperstein)
// State: DOM-only · Reload setzt alle Gruppen auf "offen" · kein localStorage
// Alle Items offline → Gruppen-Header trägt "· nicht verfügbar"
// Inhalt: AssetCard-Grid (vorher Zeilen-Liste via WatchlistItem · 4.5b refactor)

import type { WatchlistGruppeEnriched } from '../../lib/watchlistAggregator';
import AssetCard from './AssetCard.astro';

interface Props {
  gruppe: WatchlistGruppeEnriched;
}

const { gruppe } = Astro.props;

const alleOffline = gruppe.items.every((i) => !i.ist_live);
---

<section class="krypto-gruppe" data-gruppe data-expanded="true">

  <button class="krypto-gruppe-header" data-gruppe-toggle aria-expanded="true">
    <span class="gruppe-label">{gruppe.label}</span>
    {alleOffline && (
      <span class="gruppe-offline">· nicht verfügbar</span>
    )}
    <span class="gruppe-meta">{gruppe.items.length}</span>
    <span class="gruppe-chevron" aria-hidden="true">▾</span>
  </button>

  <div class="krypto-gruppe-grid">
    {gruppe.items.map((item) => (
      <AssetCard
        symbol={item.symbol}
        name={item.name}
        preis_usd={item.preis_usd}
        delta_24h_prozent={item.delta_24h_prozent}
        ist_live={item.ist_live}
        sparkline_7d={item.sparkline_7d}
      />
    ))}
  </div>

</section>

<script>
  // Toggle-Handler für alle Gruppen auf der Seite
  // Astro dedupliziert dieses Script-Modul — läuft einmal, findet alle Gruppen
  document.querySelectorAll<HTMLButtonElement>('[data-gruppe-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const gruppe = btn.closest<HTMLElement>('[data-gruppe]');
      if (!gruppe) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      gruppe.dataset.expanded = String(!isExpanded);
    });
  });
</script>

<style>
  .krypto-gruppe {
    /* kein border-top mehr — KryptoSektion staked Gruppen mit gap */
  }

  /* Inhalt ausblenden wenn zugeklappt */
  [data-gruppe][data-expanded="false"] .krypto-gruppe-grid {
    display: none;
  }

  /* Header-Button */
  .krypto-gruppe-header {
    display:         flex;
    align-items:     center;
    gap:             8px;
    width:           100%;
    background:      none;
    border:          none;
    padding:         0 0 var(--s-3) 0;
    cursor:          pointer;
    text-align:      left;
    color:           inherit;
  }

  .krypto-gruppe-header:hover .gruppe-label {
    color: var(--fg);
  }

  .gruppe-label {
    font-family:    var(--font-mono);
    font-size:      10px;
    font-weight:    600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
    transition:     color 150ms ease-out;
  }

  .gruppe-offline {
    font-family:    var(--font-mono);
    font-size:      10px;
    letter-spacing: 0.08em;
    color:          var(--fg-subtle);
    opacity:        0.6;
  }

  .gruppe-meta {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.06em;
    color:          var(--fg-faint);
    margin-left:    auto;
  }

  .gruppe-chevron {
    font-size:   12px;
    color:       var(--fg-faint);
    transition:  transform 200ms ease-out;
    flex-shrink: 0;
  }

  /* Chevron dreht sich wenn zugeklappt */
  [data-gruppe][data-expanded="false"] .gruppe-chevron {
    transform: rotate(-90deg);
  }

  /* Card-Grid · Desktop 3 Spalten · Tablet 2 · Mobile 1 — gleiches Pattern wie AktienSektion */
  .krypto-gruppe-grid {
    display:               grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:                   12px;
  }

  @media (max-width: 1023px) {
    .krypto-gruppe-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .krypto-gruppe-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
