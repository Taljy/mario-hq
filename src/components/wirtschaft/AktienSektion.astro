---
// AktienSektion — 6 US-Tech-Aktien als Cards (4.5 · in 4.5b auf AssetCard umgestellt)
// Daten: AKTIEN_DEFINITION (src/data/aktien.ts) + stand-Array vom /api/aktien-Endpoint
// Mergt sich selbst per id zu Anzeige-Items · keine Mini-Sparklines (Twelve Data
// Free Tier liefert keine brauchbare History) · dafür Tageshoch/-tief im AssetCard-extra

import type { TwelveDataStand } from '../../lib/twelveDataFetcher';
import { AKTIEN_DEFINITION } from '../../data/aktien';
import AssetCard from './AssetCard.astro';

interface Props {
  stand:      TwelveDataStand[];
  fetch_zeit: string;
}

const { stand, fetch_zeit } = Astro.props;

const standMap = new Map(stand.map((s) => [s.id, s]));

const items = AKTIEN_DEFINITION.map((def) => {
  const s = standMap.get(def.id);
  return {
    id:                def.id,
    symbol:            def.symbol,
    name:              def.name,
    preis_usd:         s?.ist_live ? s.preis_usd         : null,
    delta_24h_prozent: s?.ist_live ? s.delta_24h_prozent : null,
    ist_live:          s?.ist_live ?? false,
    tageshoch:         s?.tageshoch,
    tagestief:         s?.tagestief,
  };
});

const anyLive = items.some((i) => i.ist_live);
const stempelLabel = anyLive
  ? `Live · ${fetch_zeit}`
  : 'Twelve Data offline';
---

<section class="aktien-sektion">

  <div class="sektion-head">
    <span class="eyebrow">Aktien · US Tech</span>
    <span class={`live-stempel ${!anyLive ? 'offline' : ''}`}>{stempelLabel}</span>
  </div>

  <div class="aktien-grid">
    {items.map((item) => (
      <AssetCard
        symbol={item.symbol}
        name={item.name}
        preis_usd={item.preis_usd}
        delta_24h_prozent={item.delta_24h_prozent}
        ist_live={item.ist_live}
        tageshoch={item.tageshoch}
        tagestief={item.tagestief}
      />
    ))}
  </div>

</section>

<style>
  .aktien-sektion {
    background:    var(--bg-card);
    padding:       18px;
    border-radius: 4px;
  }

  .sektion-head {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
    margin-bottom:   var(--s-4);
  }

  .eyebrow {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--accent);
  }

  .live-stempel {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
  }

  .live-stempel.offline {
    color:   var(--accent);
    opacity: 0.7;
  }

  /* Grid: Desktop 3 Spalten · Tablet 2 · Mobile 1 — gleich wie KryptoGruppe-Grid */
  .aktien-grid {
    display:               grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:                   12px;
  }

  @media (max-width: 1023px) {
    .aktien-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .aktien-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
