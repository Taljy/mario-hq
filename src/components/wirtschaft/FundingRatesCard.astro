---
// FundingRatesCard — Funding Rates BTC/ETH/SOL · Bybit V5
// Kein Sparkline (kein History-Endpoint verfügbar)
// Extreme-Badge wenn |rate_prozent| > 0.1%

import type { FundingRate } from '../../lib/bybitFetcher';

interface Props {
  funding:   FundingRate[];
  ist_live:  boolean;
  fetch_zeit: string;
}

const { funding, ist_live, fetch_zeit } = Astro.props;

const stempelLabel = ist_live ? `Live · ${fetch_zeit}` : 'Fallback · Bybit offline';

function formatRate(r: number): string {
  const sign = r > 0 ? '+' : '';
  return `${sign}${r.toFixed(4)}%`;
}
---

<div class="indikator-card">
  <div class="card-head">
    <span class="eyebrow">Funding Rates · Bybit</span>
    <span class={`live-stempel ${!ist_live ? 'offline' : ''}`}>{stempelLabel}</span>
  </div>

  <div class="coin-liste">
    {funding.map((item) => (
      <div class="coin-row">
        <span class="coin-symbol">{item.symbol}</span>
        <div class="coin-rechts">
          <span class={`coin-rate ${item.rate_prozent < 0 ? 'negativ' : ''}`}>
            {formatRate(item.rate_prozent)}
          </span>
          {item.ist_extreme && (
            <span class="extreme-badge">Extreme</span>
          )}
        </div>
      </div>
    ))}
  </div>

  <p class="subtext">Positiv = Longs zahlen Shorts · Negativ = Shorts zahlen Longs</p>
</div>

<style>
  .indikator-card {
    background:    var(--bg-card);
    padding:       18px;
    border-radius: 4px;
    display:       flex;
    flex-direction: column;
    gap:           12px;
  }

  .card-head {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
  }

  .eyebrow {
    font-family:     var(--font-mono);
    font-size:       11px;
    font-weight:     400;
    letter-spacing:  0.12em;
    text-transform:  uppercase;
    color:           var(--accent);
  }

  .live-stempel {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
  }

  .live-stempel.offline {
    color:   var(--accent);
    opacity: 0.7;
  }

  /* Coin-Liste */
  .coin-liste {
    display:        flex;
    flex-direction: column;
    gap:            8px;
  }

  .coin-row {
    display:         flex;
    justify-content: space-between;
    align-items:     center;
  }

  .coin-symbol {
    font-family:    var(--font-mono);
    font-size:      11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
    min-width:      36px;
  }

  .coin-rechts {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .coin-rate {
    font-family: var(--font-display);
    font-size:   18px;
    font-weight: 300;
    line-height: 1;
    font-variation-settings: "opsz" 24;
    color:       var(--fg);
  }

  .coin-rate.negativ {
    color: var(--accent);
  }

  .extreme-badge {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--accent);
    border:         1px solid currentColor;
    padding:        1px 5px;
    border-radius:  2px;
  }

  .subtext {
    font-family: var(--font-mono);
    font-size:   10px;
    color:       var(--fg-subtle);
    line-height: 1.4;
    margin:      0;
  }
</style>
