---
// WatchlistGruppe — Collapsible Gruppen-Block mit Header + Items
// Toggle: Button + aria-expanded · KEIN <details> (Phase-2.1-Stolperstein)
// State: DOM-only · Reload setzt alle Gruppen auf "offen" · kein localStorage (Slice 4.4)
// Alle Items offline → Gruppen-Header trägt "· nicht verfügbar" in var(--fg-subtle)

import type { WatchlistGruppeEnriched } from '../../lib/watchlistAggregator';
import WatchlistItem from './WatchlistItem.astro';

interface Props {
  gruppe: WatchlistGruppeEnriched;
}

const { gruppe } = Astro.props;

const alleOffline = gruppe.items.every((i) => !i.ist_live);
---

<section class="wl-gruppe" data-gruppe data-expanded="true">

  <button class="wl-gruppe-header" data-gruppe-toggle aria-expanded="true">
    <span class="gruppe-label">{gruppe.label}</span>
    {alleOffline && (
      <span class="gruppe-offline">· nicht verfügbar</span>
    )}
    <span class="gruppe-meta">{gruppe.items.length}</span>
    <span class="gruppe-chevron" aria-hidden="true">▾</span>
  </button>

  <ul class="wl-gruppe-items" role="list">
    {gruppe.items.map((item) => (
      <li class="wl-item-wrapper">
        <WatchlistItem item={item} />
      </li>
    ))}
  </ul>

</section>

<script>
  // Toggle-Handler für alle Gruppen auf der Seite
  // Astro dedupliziert dieses Script-Modul — läuft einmal, findet alle Gruppen
  document.querySelectorAll<HTMLButtonElement>('[data-gruppe-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const gruppe = btn.closest<HTMLElement>('[data-gruppe]');
      if (!gruppe) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      gruppe.dataset.expanded = String(!isExpanded);
    });
  });
</script>

<style>
  .wl-gruppe {
    border-top: 1px solid var(--hairline);
  }

  /* Inhalt ausblenden wenn zugeklappt */
  [data-gruppe][data-expanded="false"] .wl-gruppe-items {
    display: none;
  }

  /* Header-Button */
  .wl-gruppe-header {
    display:         flex;
    align-items:     center;
    gap:             8px;
    width:           100%;
    background:      none;
    border:          none;
    padding:         10px 0;
    cursor:          pointer;
    text-align:      left;
    color:           inherit;
  }

  .wl-gruppe-header:hover .gruppe-label {
    color: var(--fg);
  }

  .gruppe-label {
    font-family:    var(--font-mono);
    font-size:      10px;
    font-weight:    600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
    transition:     color 150ms ease-out;
  }

  .gruppe-offline {
    font-family:    var(--font-mono);
    font-size:      10px;
    letter-spacing: 0.08em;
    color:          var(--fg-subtle);
    opacity:        0.6;
  }

  .gruppe-meta {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.06em;
    color:          var(--fg-faint);
    margin-left:    auto;
  }

  .gruppe-chevron {
    font-size:   12px;
    color:       var(--fg-faint);
    transition:  transform 200ms ease-out;
    flex-shrink: 0;
  }

  /* Chevron dreht sich wenn zugeklappt */
  [data-gruppe][data-expanded="false"] .gruppe-chevron {
    transform: rotate(-90deg);
  }

  /* Items-Liste */
  .wl-gruppe-items {
    list-style: none;
    margin:     0;
    padding:    0;
  }

  .wl-item-wrapper {
    /* letztes Item: kein border-bottom (WatchlistItem setzt es, letzte li überschreibt) */
  }

  .wl-item-wrapper:last-child > :global(.wl-item) {
    border-bottom: none;
  }
</style>
