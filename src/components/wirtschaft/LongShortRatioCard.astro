---
// LongShortRatioCard — Long/Short Ratio BTC/ETH/SOL · Bybit Konten
// Verhältnis Long zu Short · Extreme-Badge bei > 2.0 oder < 0.5
// 2h-Sparkline pro Coin (24 × 5-Min-Schnitte)

import type { LongShortRatio } from '../../lib/bybitFetcher';
import Sparkline from '../charts/Sparkline.astro';

interface Props {
  long_short: LongShortRatio[];
  ist_live:   boolean;
  fetch_zeit: string;
}

const { long_short, ist_live, fetch_zeit } = Astro.props;

const stempelLabel = ist_live ? `Live · ${fetch_zeit}` : 'Fallback · Bybit offline';
---

<div class="indikator-card">
  <div class="card-head">
    <span class="eyebrow">Long/Short Ratio · Bybit</span>
    <span class={`live-stempel ${!ist_live ? 'offline' : ''}`}>{stempelLabel}</span>
  </div>

  <div class="coin-liste">
    {long_short.map((item) => (
      <div class="coin-block">
        <div class="coin-row">
          <span class="coin-symbol">{item.symbol}</span>
          <div class="coin-rechts">
            <span class="coin-ratio">{item.ratio.toFixed(2)}</span>
            {item.ist_extreme && (
              <span class="extreme-badge">Extreme</span>
            )}
          </div>
        </div>
        {item.history_24h.length > 0 && (
          <div class="sparkline-container">
            <Sparkline values={item.history_24h} height={32} />
          </div>
        )}
      </div>
    ))}
  </div>

  <p class="subtext">Long- zu Short-Positionen Top-Trader · 5-Min-Schnitt</p>
</div>

<style>
  .indikator-card {
    background:     var(--bg-card);
    padding:        18px;
    border-radius:  4px;
    display:        flex;
    flex-direction: column;
    gap:            12px;
  }

  .card-head {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
  }

  .eyebrow {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--accent);
  }

  .live-stempel {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
  }

  .live-stempel.offline {
    color:   var(--accent);
    opacity: 0.7;
  }

  .coin-liste {
    display:        flex;
    flex-direction: column;
    gap:            10px;
  }

  .coin-block {
    display:        flex;
    flex-direction: column;
    gap:            4px;
  }

  .coin-row {
    display:         flex;
    justify-content: space-between;
    align-items:     center;
  }

  .coin-symbol {
    font-family:    var(--font-mono);
    font-size:      11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color:          var(--fg-subtle);
  }

  .coin-rechts {
    display:     flex;
    align-items: center;
    gap:         8px;
  }

  .coin-ratio {
    font-family: var(--font-display);
    font-size:   18px;
    font-weight: 300;
    line-height: 1;
    font-variation-settings: "opsz" 24;
    color:       var(--fg);
  }

  .extreme-badge {
    font-family:    var(--font-mono);
    font-size:      9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color:          var(--accent);
    border:         1px solid currentColor;
    padding:        1px 5px;
    border-radius:  2px;
  }

  .sparkline-container {
    opacity: 0.7;
  }

  .subtext {
    font-family: var(--font-mono);
    font-size:   10px;
    color:       var(--fg-subtle);
    line-height: 1.4;
    margin:      0;
  }
</style>
