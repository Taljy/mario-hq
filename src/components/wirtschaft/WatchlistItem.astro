---
// WatchlistItem — Ein Symbol mit Logo · Preis · Delta · Mini-Sparkline (Crypto · Desktop)
// Logo: selbst gerenderter Mono-Buchstabe in Sumi-Kreis · keine externen Logo-URLs
// Positives Delta: var(--fg-muted) neutral · Negatives Delta: var(--accent) Vermillon
// ist_live: false → "—" für Preis/Delta · kein Fehlertext pro Item · kein Layout-Bruch
// Sparkline: nur Crypto (anbieter=coingecko) · nur Desktop · nur wenn Daten vorhanden

import type { WatchlistItemEnriched } from '../../lib/watchlistAggregator';
import Sparkline from '../charts/Sparkline.astro';

interface Props {
  item: WatchlistItemEnriched;
}

const { item } = Astro.props;

// Logo: erster Buchstabe, bereinigt um "/"  (EUR/USD → E · BTC → B)
const logoLetter = item.symbol.replace('/', '').charAt(0).toUpperCase();

// Preis-Format: adaptiv nach Magnitude · toLocaleString('de-CH') = Schweizer Apostroph
function formatPreis(p: number): string {
  if (p >= 10000) return p.toLocaleString('de-CH', { maximumFractionDigits: 0 });
  if (p >= 100)   return p.toLocaleString('de-CH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  if (p >= 1)     return p.toLocaleString('de-CH', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  return p.toLocaleString('de-CH', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
}

function formatDelta(d: number): string {
  const sign = d >= 0 ? '+' : '';
  return `${sign}${d.toFixed(2)}%`;
}

const hatSparkline =
  item.anbieter === 'coingecko' &&
  (item.sparkline_7d?.length ?? 0) > 0;
---

<div class={`wl-item ${!item.ist_live ? 'offline' : ''}`}>

  <!-- Logo-Kreis -->
  <span class="wl-logo" aria-hidden="true">{logoLetter}</span>

  <!-- Identität: Symbol + Name -->
  <div class="wl-identity">
    <span class="wl-symbol">{item.symbol}</span>
    <span class="wl-name">{item.name}</span>
  </div>

  <!-- Preis -->
  <span class={`wl-preis ${!item.ist_live ? 'leer' : ''}`}>
    {item.preis_usd != null ? formatPreis(item.preis_usd) : '—'}
  </span>

  <!-- Delta -->
  <span class={`wl-delta ${item.ist_live && item.delta_24h_prozent != null && item.delta_24h_prozent < 0 ? 'negativ' : ''} ${!item.ist_live ? 'leer' : ''}`}>
    {item.delta_24h_prozent != null ? formatDelta(item.delta_24h_prozent) : '—'}
  </span>

  <!-- Mini-Sparkline · Crypto · Desktop only -->
  <div class="wl-sparkline-cell">
    {hatSparkline && (
      <Sparkline values={item.sparkline_7d!} height={20} />
    )}
  </div>

</div>

<style>
  .wl-item {
    display:       grid;
    /* Mobile: logo | identity | preis | delta (sparkline-cell versteckt) */
    grid-template-columns: 26px 1fr auto auto 0px;
    align-items:   center;
    gap:           0 10px;
    padding:       8px 0;
    border-bottom: 1px solid var(--hairline);
  }

  @media (min-width: 641px) {
    .wl-item {
      /* Desktop: logo | identity | preis | delta | sparkline */
      grid-template-columns: 26px 1fr 96px 60px 80px;
      gap: 0 12px;
    }
  }

  /* Logo-Kreis */
  .wl-logo {
    width:          26px;
    height:         26px;
    border-radius:  50%;
    border:         1px solid var(--hairline-strong);
    display:        flex;
    align-items:    center;
    justify-content: center;
    font-family:    var(--font-mono);
    font-size:      10px;
    font-weight:    600;
    letter-spacing: 0;
    color:          var(--fg-subtle);
    flex-shrink:    0;
  }

  /* Identität */
  .wl-identity {
    display:   flex;
    align-items: center;
    gap:       7px;
    min-width: 0;
    overflow:  hidden;
  }

  .wl-symbol {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    600;
    letter-spacing: 0.04em;
    color:          var(--fg);
    white-space:    nowrap;
    flex-shrink:    0;
  }

  .wl-name {
    font-family:   var(--font-body);
    font-size:     11px;
    color:         var(--fg-subtle);
    white-space:   nowrap;
    overflow:      hidden;
    text-overflow: ellipsis;
  }

  /* Preis */
  .wl-preis {
    font-family:    var(--font-display);
    font-size:      14px;
    font-weight:    300;
    line-height:    1;
    font-variation-settings: "opsz" 18;
    color:          var(--fg);
    text-align:     right;
    white-space:    nowrap;
  }

  /* Delta */
  .wl-delta {
    font-family:    var(--font-mono);
    font-size:      11px;
    color:          var(--fg-muted);
    text-align:     right;
    white-space:    nowrap;
  }

  .wl-delta.negativ {
    color: var(--accent);
  }

  /* Offline-Zustand: Werte ausgeblendet, Layout intakt */
  .wl-preis.leer,
  .wl-delta.leer {
    color: var(--fg-faint);
  }

  /* Sparkline-Zelle */
  .wl-sparkline-cell {
    display:  none;
    width:    80px;
    overflow: hidden;
  }

  @media (min-width: 641px) {
    .wl-sparkline-cell {
      display: block;
    }
  }
</style>
