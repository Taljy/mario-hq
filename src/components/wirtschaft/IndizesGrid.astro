---
// IndizesGrid — 4 Indizes-Karten · statische JSON-Werte · Cowork füllt ab Phase 5
// delta === 0 → "flat" · negativ → Vermillon · positiv → neutral

import type { Index } from '../../lib/wirtschaftResolver';

interface Props {
  indizes: Index[];
}

const { indizes } = Astro.props;

function formatDelta(d: number): string {
  if (d === 0) return 'flat';
  return `${d > 0 ? '+' : ''}${d.toFixed(1)}%`;
}
---

<div class="indizes-sektion">
  <span class="sektion-eyebrow">Indizes</span>
  <div class="indizes-grid">
    {indizes.map((idx) => {
      const delta   = formatDelta(idx.delta_prozent);
      const negativ = idx.delta_prozent < 0;
      return (
        <div class="index-card">
          <span class="index-name">{idx.name}</span>
          <span class="index-wert">{idx.wert.toLocaleString('de-CH')}</span>
          <span class={`index-delta ${negativ ? 'negativ' : ''}`}>{delta}</span>
        </div>
      );
    })}
  </div>
</div>

<style>
  .sektion-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: var(--s-3);
  }

  .indizes-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .index-card {
    background: var(--bg-card);
    padding: 18px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .index-name {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .index-wert {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 28px;
    line-height: 1;
    font-variation-settings: "opsz" 48;
    color: var(--fg);
  }

  .index-delta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .index-delta.negativ {
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .indizes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
