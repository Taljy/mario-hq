---
// MacroCard — Supporting-Grid Mitte (1fr) · LIVE seit Slice 5.3
// 3er-Vorausschau auf wichtige Macro-Events (impact kritisch || hoch) ab heute
// Quelle: macroEventsResolver.getNaechsteWichtigeEvents() · Mario-gepflegtes JSON
// Kein Live-Stempel · kein Puls · keine Indizes-Zeile (Mario-Entscheidungen Phase 5)
// Defensive: bei 0 Events graceful leer-Hinweis, bei <3 entsprechend weniger Zeilen

import { getNaechsteWichtigeEvents } from '../lib/macroEventsResolver';
import type { MacroEvent } from '../lib/macroEventsResolver';

const events: MacroEvent[] = getNaechsteWichtigeEvents(3);
const heuteIso = new Date().toISOString().slice(0, 10);

function formatDatum(iso: string): string {
  if (iso === heuteIso) return 'Heute';
  // "DD. Monat" via Intl, deutsche Schreibweise · z.B. "19. Mai"
  const d = new Date(iso + 'T12:00:00Z');
  return d.toLocaleDateString('de-CH', {
    day:      'numeric',
    month:    'long',
    timeZone: 'Europe/Zurich',
  });
}
---

<div class="macro-card">
  <!-- Header-Row: nur Eyebrow, kein Live-Stempel (JSON-gepflegt, nicht live) -->
  <div class="card-head">
    <span class="eyebrow">Macro</span>
  </div>

  <!-- Body: 3er-Vorausschau · oder graceful Leer-Hinweis bei 0 Events -->
  {events.length === 0 ? (
    <p class="leer-hinweis">Keine wichtigen Macro-Events in den nächsten 14 Tagen.</p>
  ) : (
    <ul class="event-liste" role="list">
      {events.map((e) => (
        <li class="event-zeile">
          <span class="event-datum">{formatDatum(e.datum)}</span>
          <span class="event-zeit">{e.uhrzeit}</span>
          <span class="event-name">{e.name}</span>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .macro-card {
    background:    var(--bg-card);
    padding:       18px;
    border-radius: 4px;
  }

  .card-head {
    display:       flex;
    align-items:   baseline;
    margin-bottom: var(--s-4);
  }

  .eyebrow {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--accent);
  }

  /* Body */
  .leer-hinweis {
    margin:      0;
    font-family: var(--font-display);
    font-style:  italic;
    font-size:   12px;
    color:       var(--fg-muted);
    line-height: 1.4;
  }

  .event-liste {
    list-style:     none;
    margin:         0;
    padding:        0;
    display:        flex;
    flex-direction: column;
    gap:            10px;
  }

  .event-zeile {
    display:               grid;
    grid-template-columns: auto auto 1fr;
    align-items:           baseline;
    column-gap:            10px;
    row-gap:               2px;
  }

  .event-datum {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    600;
    letter-spacing: 0.04em;
    color:          var(--fg);
    white-space:    nowrap;
  }

  .event-zeit {
    font-family: var(--font-mono);
    font-size:   10px;
    color:       var(--fg-subtle);
    white-space: nowrap;
  }

  .event-name {
    font-size:   12px;
    color:       var(--fg-muted);
    line-height: 1.4;
  }

  /* Mobile: Datum + Zeit in Zeile 1, Name in Zeile 2 (kompakter auf 375px) */
  @media (max-width: 480px) {
    .event-zeile {
      grid-template-columns: auto auto;
      grid-template-areas:
        "datum zeit"
        "name name";
    }
    .event-datum { grid-area: datum; }
    .event-zeit  { grid-area: zeit; justify-self: end; }
    .event-name  { grid-area: name; }
  }
</style>
