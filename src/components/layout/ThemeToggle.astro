---

<button type="button" id="theme-toggle" class="theme-toggle" aria-label="Theme wechseln">
  <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <line x1="12" y1="2" x2="12" y2="4" />
    <line x1="12" y1="20" x2="12" y2="22" />
    <line x1="2" y1="12" x2="4" y2="12" />
    <line x1="20" y1="12" x2="22" y2="12" />
    <line x1="4.93" y1="4.93" x2="6.34" y2="6.34" />
    <line x1="17.66" y1="17.66" x2="19.07" y2="19.07" />
    <line x1="4.93" y1="19.07" x2="6.34" y2="17.66" />
    <line x1="17.66" y1="6.34" x2="19.07" y2="4.93" />
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .theme-toggle {
    background: none;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    padding: 6px;
    cursor: pointer;
    color: var(--fg-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 200ms ease-out, border-color 200ms ease-out;
  }
  .theme-toggle:hover {
    color: var(--fg);
    border-color: var(--hairline-strong);
  }
  .icon { width: 16px; height: 16px; }

  /* Im Light-Modus sichtbar = Mond (Klick → Dark). Im Dark-Modus = Sonne (Klick → Light). */
  :root[data-theme="light"] .icon-sun  { display: none; }
  :root[data-theme="dark"]  .icon-moon { display: none; }
</style>
