---
// WetterWochenBars — ECharts vertikale Floating-Bars · Min/Max-Temperatur über 7 Tage
// Astro-Islands-Pattern: SSR rendert leeres div mit data-Attribut · Client-Script
// initialisiert via IntersectionObserver (lazy) · DRG-Theme zwingend · keine Tooltips
// X-Achse: Wochentage (Mo–So) · Y-Achse: Temperatur in °C

import type { WetterTag } from '../../lib/openMeteoFetcher';

interface Props {
  woche: WetterTag[];
}

const { woche } = Astro.props;

const daten = {
  wochentage: woche.map((t) => t.wochentag_kurz),
  min:        woche.map((t) => Math.round(t.min)),
  max:        woche.map((t) => Math.round(t.max)),
};

const chartId = `wwb-${Math.random().toString(36).slice(2, 9)}`;
---

<section class="wochen-bars-sektion">
  <div class="sektion-head">
    <span class="eyebrow">Wetter · Woche</span>
    <span class="hint">Min / Max in °C</span>
  </div>
  <div
    id={chartId}
    class="wochen-bars-wrap"
    data-wochen-bars
    data-daten={JSON.stringify(daten)}
    aria-hidden="true"
  ></div>
</section>

<script>
  import { initWetterWochenBars, type WetterWochenBarsDaten } from '../../lib/echartsRenderer';

  function setup() {
    document.querySelectorAll<HTMLElement>('[data-wochen-bars]').forEach((el) => {
      const raw = el.dataset.daten;
      if (!raw) return;

      let daten: WetterWochenBarsDaten;
      try {
        daten = JSON.parse(raw) as WetterWochenBarsDaten;
      } catch {
        return;
      }
      if (daten.wochentage.length === 0) return;

      let initialized = false;
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !initialized) {
              initialized = true;
              initWetterWochenBars(el, daten);
              io.disconnect();
            }
          });
        },
        { threshold: 0.1 },
      );
      io.observe(el);
    });
  }

  setup();
</script>

<style>
  .wochen-bars-sektion {
    background:    var(--bg-card);
    padding:       18px;
    border-radius: 4px;
  }

  .sektion-head {
    display:         flex;
    justify-content: space-between;
    align-items:     baseline;
    margin-bottom:   var(--s-3);
  }

  .eyebrow {
    font-family:    var(--font-mono);
    font-size:      11px;
    font-weight:    400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color:          var(--accent);
  }

  .hint {
    font-family:    var(--font-mono);
    font-size:      10px;
    letter-spacing: 0.08em;
    color:          var(--fg-subtle);
  }

  .wochen-bars-wrap {
    width:  100%;
    height: 120px;
  }
</style>
