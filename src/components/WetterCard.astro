---
// WetterCard — Co-Hero links (1.7fr) · LIVE (Slice 5.2b)
// Quellen: getWetterErgebnis() (Open-Meteo) · getStundenHeute() (SunCalc, lokal)
//          getFotoEmpfehlung() (kuratierte Foto-Spots)
// Symbol via zentralen WetterSymbol-Wrapper (8 SVG-Sub-Komponenten)
// Stunden-Formatierung in der Card (View-Logik): "{start} — {ende}" Em-Dash U+2014
// niederschlag_mm bewusst nicht angezeigt · Layout-Treue · WetterDetail zeigt es

import WetterSymbol           from './wetter-symbole/WetterSymbol.astro';
import type { WetterErgebnis } from '../lib/openMeteoFetcher';
import type { StundenHeute }   from '../lib/astronomieResolver';
import type { FotoEmpfehlung } from '../lib/fotoSpotPicker';

interface Props {
  wetter:  WetterErgebnis;
  stunden: StundenHeute;
  foto:    FotoEmpfehlung;
}

const { wetter, stunden, foto } = Astro.props;

const stempelLabel = wetter.ist_live
  ? `Live · ${wetter.fetch_zeit}`
  : 'Fallback · Open-Meteo offline';

// Em-Dash U+2014 mit Leerzeichen — wie in der Stub-Card-Vorlage
const goldenRange = `${stunden.goldene_stunde.start} — ${stunden.goldene_stunde.ende}`;
const blauerRange = `${stunden.blaue_stunde.start} — ${stunden.blaue_stunde.ende}`;
---

<div class="wetter-card">
  <!-- Header-Row: Eyebrow links · Live-Stempel rechts (flex space-between, analog KryptoCard) -->
  <div class="card-head">
    <span class="eyebrow">Wetter &amp; Foto · {wetter.ort}</span>
    <span class={`live-stempel ${!wetter.ist_live ? 'offline' : ''}`}>{stempelLabel}</span>
  </div>

  <!-- Hero-Row: Symbol + Temperatur + Bedingung nebeneinander -->
  <div class="hero-row">
    <WetterSymbol wmoCode={wetter.heute.wmo_code} size={64} />

    <!-- Temperatur -->
    <div class="temp-block">
      <span class="temp">{wetter.heute.temperatur}°</span>
      <span class="min">Min {wetter.heute.min}°</span>
    </div>

    <!-- Bedingung + Wind -->
    <div class="bedingung-block">
      <span class="bedingung">{wetter.heute.bedingung}</span>
      <span class="wind">{wetter.heute.wind_richtung} {wetter.heute.wind_kmh} km/h</span>
    </div>
  </div>

  <!-- Sub-Grid: Goldene + Blaue Stunde -->
  <div class="stunden-grid">
    <div class="stunde">
      <span class="stunde-eyebrow">Goldene Stunde</span>
      <span class="stunde-wert">{goldenRange}</span>
    </div>
    <div class="stunde">
      <span class="stunde-eyebrow">Blaue Stunde</span>
      <span class="stunde-wert">{blauerRange}</span>
    </div>
  </div>

  <!-- Foto-Hinweis -->
  <p class="foto-hinweis">{foto.begruendung}</p>
</div>

<style>
  .wetter-card {
    background: var(--bg-card);
    padding: 22px;
    border-radius: 4px;
  }

  /* Header-Row mit Eyebrow + Live-Stempel · Pattern aus KryptoCard (5.1) */
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s-4);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .live-stempel {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .live-stempel.offline {
    color:   var(--accent);
    opacity: 0.7;
  }

  /* Hero-Row — Symbol + Temp + Bedingung nebeneinander */
  .hero-row {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    margin-bottom: var(--s-4);
  }

  .temp-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .temp {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 52px;
    line-height: 1;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .min {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  .bedingung-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bedingung {
    font-size: 13px;
    color: var(--fg);
    line-height: 1.4;
  }

  .wind {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-subtle);
  }

  /* Sub-Grid: Goldene + Blaue Stunde */
  .stunden-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding-top: var(--s-3);
    border-top: 1px solid var(--hairline);
    margin-bottom: var(--s-3);
  }

  .stunde {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .stunde-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .stunde-wert {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg);
  }

  /* Foto-Hinweis */
  .foto-hinweis {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.4;
    border-top: 1px solid var(--hairline);
    padding-top: var(--s-3);
  }
</style>
