---
// EventBanner — STILLGELEGT in Slice 5.3 (14.5.2026)
// In index.astro nicht mehr eingebunden · MacroCard-3er-Vorausschau übernimmt
// die Macro-Information auf dem Cover · ruhigerer Cover-Charakter.
//
// Wiederanschluss-Anleitung (~10 min):
//   1. eventResolver wurde in 5.3 gelöscht · Import unten umstellen auf
//      macroEventsResolver.getHeutigesBannerEvent() (Helper neu anlegen,
//      Trigger: impact === 'kritisch' || 'hoch', datum === heute)
//   2. Felder-Mapping: MacroEvent hat name/uhrzeit · keine beschreibung
//      → Template anpassen (Banner-Text z.B. "Heute · {uhrzeit} · {name}")
//   3. In src/pages/index.astro Import + <EventBanner /> wieder einhängen
//
// Datei bleibt mit gebrochenem Import — Build ignoriert sie weil nicht
// imported. Astro bundelt nur referenzierte Komponenten.

import { getAktivenEvent } from '../lib/eventResolver';

const event = getAktivenEvent();
---

{event && (
  <div class="event-banner">
    <span class="zeit">Heute · {event.uhrzeit}</span>
    <span class="titel">{event.titel}</span>
    <span class="beschr">· {event.beschreibung}</span>
  </div>
)}

<style>
  .event-banner {
    background: rgba(227, 66, 52, 0.06);
    border-left: 3px solid var(--accent);
    padding: 10px 14px;
    border-radius: 0 4px 4px 0;
    margin-block: 14px;
  }

  /* Zeit-Stempel in Vermillon-deep — betont aber nicht aggressiv */
  .zeit {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-hover);
    font-weight: 500;
    margin-right: 12px;
  }

  .titel {
    font-size: 13px;
    color: var(--fg);
    font-weight: 500;
    margin-right: 4px;
  }

  .beschr {
    font-size: 13px;
    color: var(--fg-muted);
  }

  /* Dark-Mode — 0.06 auf #1A1A1A fast unsichtbar · 0.12 gibt Wärme ohne zu dominieren */
  :root[data-theme="dark"] .event-banner {
    background: rgba(227, 66, 52, 0.12);
  }
</style>
